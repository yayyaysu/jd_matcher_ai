PROJECT_NAME=JD Matcher v2 API
APP_VERSION=0.1.0
DOCKERHUB_USERNAME=

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=jd_matcher
MYSQL_USER=jd_user
MYSQL_PASSWORD=jd_password
MYSQL_ROOT_PASSWORD=root_password

REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600
API_BASE_URL=http://api:8000
OPENAI_API_KEY=
PARSER_MODEL=gpt-4.1-mini
STRATEGIST_MODEL=gpt-4.1-mini
ANALYSIS_VERSION=1
RESUME_PATH=data/resume.txt
OUTPUTS_DIR=data/outputs
